<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ business.seoTitle }}</title>
<meta name="description" content="{{ business.seoDescription }}">
<meta name="keywords" content="{{ business.seoKeywords }}">
<meta name="robots" content="index, follow">
<meta name="theme-color" content="#0a0a0a">
<link rel="canonical" href="{{ business.siteUrl }}/">
{% if business.favicon %}<link rel="icon" href="{{ business.favicon }}">{% endif %}

<!-- Open Graph -->
<meta property="og:type" content="website">
<meta property="og:site_name" content="{{ business.name }}">
<meta property="og:title" content="{{ business.seoTitle }}">
<meta property="og:description" content="{{ business.seoDescription }}">
<meta property="og:locale" content="en_US">
<meta property="og:url" content="{{ business.siteUrl }}/">
{% if business.ogImage %}<meta property="og:image" content="{{ business.ogImage }}">{% endif %}
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ business.seoTitle }}">
<meta name="twitter:description" content="{{ business.seoDescription }}">
{% if business.ogImage %}<meta name="twitter:image" content="{{ business.ogImage }}">{% endif %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700;800;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<!-- LocalBusiness Schema -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "@id": "{{ business.siteUrl | safe }}/#business",
  "name": "{{ business.name | safe }}",
  "alternateName": "{{ business.name | safe }} Marketing",
  "description": "{{ business.seoDescription | safe }}",
  "url": "{{ business.siteUrl | safe }}/",
  "telephone": "{{ business.phoneHref | safe }}",
  "email": "{{ business.email | safe }}",
  {% if business.logoImage %}"image": "{{ business.logoImage | safe }}",
  "logo": "{{ business.logoImage | safe }}",
  {% endif %}"slogan": "{{ business.tagline | safe }}",
  "priceRange": "$$",
  "currenciesAccepted": "USD",
  "paymentAccepted": "Cash, Credit Card, ACH",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "{{ business.addressStreet | safe }}",
    "addressLocality": "{{ business.addressCity | safe }}",
    "addressRegion": "{{ business.addressState | safe }}",
    "postalCode": "{{ business.addressZip | safe }}",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": {{ business.geoLat }},
    "longitude": {{ business.geoLng }}
  },
  "areaServed": [
    {%- for a in local.areas %}
    { "@type": "City", "name": "{{ a.name | safe }}" }{% if not loop.last %},{% endif %}
    {%- endfor %}
  ],
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
      "opens": "08:00",
      "closes": "18:00"
    }
  ],
  "sameAs": [
    "{{ business.facebook | safe }}",
    "{{ business.instagram | safe }}",
    "{{ business.linkedin | safe }}"
  ],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Marketing Services",
    "itemListElement": [
      {%- for s in services.items %}
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "{{ s.tag | safe }}", "description": "{{ s.desc | safe }}" } }{% if not loop.last %},{% endif %}
      {%- endfor %}
    ]
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "{{ reviews.rating | safe }}",
    "reviewCount": "47"
  }
}
</script>

<link rel="stylesheet" href="/css/styles.css">
</head>
<body>
<div class="spark-bar"></div>

<!-- ===== NAV ===== -->
{% include "nav.njk" %}

<!-- ===== HERO ===== -->
<section class="hero">
  <div class="wrap">
    <div class="hero-grid">
      <div class="hero-left reveal">
        <span class="hero-badge"><span class="dot"></span>{{ hero.badge }}</span>
        <h1>{{ hero.headlineLead }} <span class="hl">{{ hero.headlineHighlight }}</span></h1>
        <p class="sub">{{ hero.subheadline }}</p>
        <div class="hero-ctas">
          <a href="#contact" class="btn btn-primary btn-lg">{{ hero.primaryCta }}
            <svg class="bolt" viewBox="0 0 24 24" fill="currentColor"><path d="M13 2 4.5 13.5H11l-1 8.5L19.5 10H13z"/></svg>
          </a>
          <a href="#contact" class="btn btn-ghost btn-lg">{{ hero.secondaryCta }}</a>
        </div>
        <div class="trust-row">
          {% for t in hero.trust %}
          <span class="ti">{% if loop.index == 1 %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 12-9 12s-9-5-9-12a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>{% elif loop.index == 2 %}<svg viewBox="0 0 24 24" fill="currentColor"><path d="M13 2 4.5 13.5H11l-1 8.5L19.5 10H13z"/></svg>{% elif loop.index == 3 %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="m9 11 3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>{% else %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>{% endif %}{{ t.text }}</span>
          {% endfor %}
        </div>
      </div>

      <div class="hero-right reveal d2">
        <div class="hero-card">
          <div class="glow-ring"></div>
          <div class="hc-top">
            <span>{{ hero.snapshotTitle }}</span>
            <span class="live-dot"><i></i>LIVE</span>
          </div>
          <div class="hc-bars">
            {% for bar in hero.snapshotBars %}
            <div class="hc-bar">
              <label>{{ bar.label }} <b>{{ bar.value }}</b></label>
              <div class="hc-track"><div class="hc-fill" data-w="{{ bar.width }}"></div></div>
            </div>
            {% endfor %}
          </div>
          <div class="hc-foot">
            <span class="big">{{ hero.snapshotFootNumber }}</span>
            <span class="lbl">{{ hero.snapshotFootLabel }}</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===== SERVICES ===== -->
<section class="services pad" id="services">
  <div class="wrap">
    <div class="section-head reveal">
      <span class="eyebrow"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M13 2 4.5 13.5H11l-1 8.5L19.5 10H13z"/></svg>{{ services.eyebrow }}</span>
      <h2>{{ services.titleLead }} <span class="lime">{{ services.titleHighlight }}</span></h2>
      <p>{{ services.intro }}</p>
    </div>

    <div class="cards">
      {% for s in services.items %}
      <article class="card reveal d{{ loop.index }}">
        <div class="ico">{% if loop.index == 1 %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>{% elif loop.index == 2 %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8m-4-4v4"/></svg>{% elif loop.index == 3 %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12a10 10 0 1 0 20 0 10 10 0 0 0-20 0z"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20zM2 12h20"/></svg>{% else %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="8" width="16" height="12" rx="2"/><path d="M12 8V4m-4 4V5m8 3V5"/><circle cx="9" cy="14" r="1"/><circle cx="15" cy="14" r="1"/></svg>{% endif %}</div>
        <span class="tag">{{ s.tag }}</span>
        <h3>{{ s.title }}</h3>
        <p>{{ s.desc }}</p>
        <ul>
          {% for b in s.bullets %}
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 5 5L20 7"/></svg>{{ b }}</li>
          {% endfor %}
        </ul>
      </article>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ===== RESULTS / VALUE PROP ===== -->
<section class="results pad alt" id="results">
  <div class="wrap">
    <div class="results-grid">
      <div class="results-copy reveal">
        <span class="eyebrow"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M13 2 4.5 13.5H11l-1 8.5L19.5 10H13z"/></svg>{{ results.eyebrow }}</span>
        <h2>{{ results.titleLead }} <span class="lime">{{ results.titleHighlight }}</span></h2>
        {% for p in results.paragraphs %}<p>{{ p }}</p>
        {% endfor %}<p class="lead-line">{{ results.leadLine }}</p>
        <div class="hero-ctas" style="margin-top:30px">
          <a href="{{ results.ctaHref }}" class="btn btn-ghost">{{ results.ctaLabel }}</a>
        </div>
      </div>
      <div class="stats reveal d2">
        {% for st in results.stats %}
        <div class="stat"><div class="num" data-count="{{ st.count }}" data-suffix="{{ st.suffix }}">0</div><div class="lbl">{{ st.label }}</div></div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<!-- ===== LOCAL TRUST ===== -->
<section class="local pad" id="local">
  <div class="wrap">
    <div class="local-grid">
      <div class="local-copy reveal">
        <span class="eyebrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 12-9 12s-9-5-9-12a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>{{ local.eyebrow }}</span>
        <h2>{{ local.titleLead }} <span class="lime">{{ local.titleHighlight }}</span> {{ local.titleEnd }}</h2>
        {% for p in local.paragraphs %}<p>{{ p }}</p>
        {% endfor %}{% if local.image %}<img src="{{ local.image }}" alt="{{ business.name }} serving {{ business.addressCity }}, {{ business.addressState }}" class="local-photo">{% endif %}
        <div class="areas">
          {% for a in local.areas %}<span class="{% if a.hq %}hq{% endif %}">{{ a.name }}</span>
          {% endfor %}
        </div>
      </div>

      <div class="pains reveal d2">
        {% for pain in local.pains %}
        <div class="pain">
          <div class="pi">{% if loop.index == 1 %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>{% elif loop.index == 2 %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>{% else %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>{% endif %}</div>
          <div><h4>{{ pain.title }}</h4><p>{{ pain.body }}</p></div>
        </div>
        {% endfor %}
        <a href="#contact" class="btn btn-primary" style="margin-top:6px">{{ local.ctaLabel }}
          <svg class="bolt" viewBox="0 0 24 24" fill="currentColor"><path d="M13 2 4.5 13.5H11l-1 8.5L19.5 10H13z"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ===== PROCESS ===== -->
<section class="process pad alt" id="process">
  <div class="wrap">
    <div class="section-head reveal" style="max-width:none;text-align:center;margin-left:auto;margin-right:auto">
      <span class="eyebrow" style="justify-content:center"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M13 2 4.5 13.5H11l-1 8.5L19.5 10H13z"/></svg>{{ process.eyebrow }}</span>
      <h2>{{ process.titleLead }} <span class="lime">{{ process.titleHighlight }}</span></h2>
    </div>
    <div class="steps">
      {% for step in process.steps %}
      <div class="step reveal d{{ loop.index }}">
        {% if loop.index == 1 %}<svg class="stepico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>{% elif loop.index == 2 %}<svg class="stepico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a4 4 0 0 0-5.6 5.6l-6 6a2 2 0 1 0 2.8 2.8l6-6a4 4 0 0 0 5.6-5.6l-2.1 2.1-2.8-2.8z"/></svg>{% else %}<svg class="stepico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>{% endif %}
        <div class="n">{{ step.n }}</div>
        <h3>{{ step.title }}</h3>
        <p>{{ step.body }}</p>
      </div>
      {% endfor %}
    </div>
    <div style="text-align:center;margin-top:46px" class="reveal">
      <a href="#contact" class="btn btn-primary btn-lg">{{ process.ctaLabel }}</a>
    </div>
  </div>
</section>

<!-- ===== REVIEWS ===== -->
<section class="reviews-sec pad" id="reviews">
  <div class="wrap">
    <div class="rev-head reveal">
      <div class="section-head" style="margin-bottom:0">
        <span class="eyebrow"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M13 2 4.5 13.5H11l-1 8.5L19.5 10H13z"/></svg>{{ reviews.eyebrow }}</span>
        <h2>{{ reviews.titleLead }} <span class="lime">{{ reviews.titleHighlight }}</span></h2>
      </div>
      <div class="gbadge">
        <div class="rate">{{ reviews.rating }}</div>
        <div><div class="stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div><small>{{ reviews.ratingLabel }}</small></div>
      </div>
    </div>

    <div class="reviews">
      {% for r in reviews.items %}
      <div class="review reveal d{{ loop.index }}">
        <div class="stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <p>&ldquo;{{ r.quote }}&rdquo;</p>
        <div class="who"><div class="av">{% if r.avatar %}<img src="{{ r.avatar }}" alt="{{ r.name }}">{% else %}{{ r.initials }}{% endif %}</div><div><b>{{ r.name }}</b><span>{{ r.meta }}</span></div></div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ===== CTA / CONTACT ===== -->
<section class="cta pad alt" id="contact">
  <div class="wrap">
    <div class="cta-box reveal">
      <div class="cta-l">
        <span class="eyebrow"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M13 2 4.5 13.5H11l-1 8.5L19.5 10H13z"/></svg>{{ cta.eyebrow }}</span>
        <h2>{{ cta.titleLead }} <span class="lime">{{ cta.titleHighlight }}</span></h2>
        <p>{{ cta.body }}</p>
        <div class="cta-call">
          <span class="ph-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg></span>
          <a href="tel:{{ business.phoneHref }}">{{ business.phone }}</a>
        </div>
        <p class="cta-sub">{{ cta.subline }}</p>
      </div>

      <div class="cta-r">
        <form class="lead" id="leadForm" name="lead" method="POST" data-netlify="true" netlify-honeypot="bot-field" novalidate>
          <input type="hidden" name="form-name" value="lead">
          <p class="hpot"><label>Don&rsquo;t fill this out if you&rsquo;re human: <input name="bot-field"></label></p>
          <div class="field"><label for="name">Your Name</label><input type="text" id="name" name="name" placeholder="Jordan Smith" required></div>
          <div class="frow">
            <div class="field"><label for="biz">Business Name</label><input type="text" id="biz" name="business" placeholder="Smith Plumbing"></div>
            <div class="field"><label for="phone">Phone</label><input type="tel" id="phone" name="phone" placeholder="(636) 555-0123" required></div>
          </div>
          <div class="field"><label for="email">Email</label><input type="email" id="email" name="email" placeholder="you@business.com" required></div>
          <div class="field"><label for="service">What do you need most?</label>
            <select id="service" name="service">
              <option value="">Choose a service&hellip;</option>
              {% for opt in cta.serviceOptions %}<option>{{ opt }}</option>
              {% endfor %}
            </select>
          </div>
          <button type="submit" class="btn btn-primary btn-lg">{{ cta.buttonLabel }}
            <svg class="bolt" viewBox="0 0 24 24" fill="currentColor"><path d="M13 2 4.5 13.5H11l-1 8.5L19.5 10H13z"/></svg>
          </button>
          <p class="formnote">{{ cta.formNote }}</p>
        </form>
        <div class="form-success" id="formSuccess">
          <div class="chk"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 5 5L20 7"/></svg></div>
          <h3>{{ cta.successTitle }}</h3>
          <p>{{ cta.successBody }} <a href="tel:{{ business.phoneHref }}" class="lime">{{ business.phone }}</a></p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===== FOOTER ===== -->
{% include "footer.njk" %}

{% include "scripts.njk" %}
</body>
</html>
